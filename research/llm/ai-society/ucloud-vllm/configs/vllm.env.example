# Heimdall vLLM local serving config
# Copy to /work/heimdall-vllm/.env and edit if needed.

HEIMDALL_MODEL=Qwen/Qwen3-32B
HEIMDALL_VLLM_HOST=127.0.0.1
HEIMDALL_VLLM_PORT=8000
HEIMDALL_VLLM_API_KEY=heimdall-local

# Current AI-society matrix default on one UCloud B200 endpoint. Run two
# independent copies for real matrices: GPU0 on port 8000 and GPU1 on port 8001.
# For lighter dev or explicit model-ladder smoke tests, use Qwen/Qwen3-4B and a
# smaller context only after checking prompt size and output budget.
HEIMDALL_TENSOR_PARALLEL_SIZE=1
HEIMDALL_MAX_MODEL_LEN=16384
HEIMDALL_GPU_MEMORY_UTILIZATION=0.60
HEIMDALL_DTYPE=auto
HEIMDALL_TRUST_REMOTE_CODE=0
HEIMDALL_ATTENTION_BACKEND=TRITON_ATTN

# UCloud B200 images may not include nvcc or a compatible DeepGEMM package.
VLLM_USE_DEEP_GEMM=0
# vLLM >=0.21 routes top-k/top-p sampling through FlashInfer, whose JIT kernel needs nvcc
# (absent on the validated UCloud image) and crashes engine-core init with
# "Could not find nvcc". Force the native PyTorch sampler. (vLLM 0.20.2 did not need this.)
VLLM_USE_FLASHINFER_SAMPLER=0

# Extra args are appended to vllm serve.
# Eager mode avoids CUDA graph JIT paths that require nvcc on some UCloud images.
# qwen3_xml enables named tool_choice requests. moe-backend triton avoids
# FlashInfer TRTLLM MoE JIT paths on UCloud images without nvcc.
HEIMDALL_VLLM_EXTRA_ARGS="--enforce-eager --enable-auto-tool-choice --tool-call-parser qwen3_xml --moe-backend triton"

# For Qwen3 auto tool parsing:
# HEIMDALL_VLLM_EXTRA_ARGS="--enforce-eager --enable-auto-tool-choice --tool-call-parser qwen3_xml"

# Tested public models on this branch:
# Qwen/Qwen3-0.6B, Qwen/Qwen3-1.7B, Qwen/Qwen3-4B, Qwen/Qwen3-8B,
# Qwen/Qwen3-14B, Qwen/Qwen3-30B-A3B, Qwen/Qwen3-32B.
